# Frontend environment variables.
# Copy to .env (or .env.local) and fill in what you need — every variable has
# a working default for local development, so an empty file is fine.
#
# NEXT_PUBLIC_* values are inlined into the client bundle at BUILD time:
# changing one in production requires `npm run build`, not just a restart.
# If you point these at a new host, remember the CSP in next.config.js
# whitelists specific origins (connect-src / media-src).

# Keystone backend origin.
# Defaults: http://localhost:4444 (dev) / https://backend.mindhive.science (prod builds)
#NEXT_PUBLIC_BACKEND_URL=

# Realtime collaboration (Hocuspocus) origin. The WebSocket URL becomes
# <origin, http→ws>/collaboration.
# Defaults: http://localhost:4445 (dev) / the backend origin (prod builds,
# where nginx routes /collaboration to the collab process)
#NEXT_PUBLIC_COLLAB_URL=

# Server-only (never sent to the browser): Notion integration key used by
# GET /api/notion.
#NOTION_KEY=

# Optional override to point the research export tooling at a different
# backend; defaults to the shared GraphQL endpoint.
#NEXT_PUBLIC_RESEARCH_EXPORT_ENDPOINT=

# Client-exposed OpenAI key for the ChatGPT simulation blocks; leave empty to
# disable them. NOTE: anything NEXT_PUBLIC_ is visible to every visitor.
#NEXT_PUBLIC_OPENAI_KEY=
