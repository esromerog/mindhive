# Keystone backend environment variables.
# Copy to .env and fill in the values. Do NOT commit your real .env — it holds
# secrets and is gitignored.
#
# Many hosts/URLs are selected by NODE_ENV: "development" uses the *_DEV
# variants and SQLite; anything else uses the production variants and
# PostgreSQL (see keystone.ts).

# development | production
NODE_ENV=development

# Keystone (Admin UI + GraphQL API) port.
PORT=4444
# Realtime collaboration (Hocuspocus) WebSocket server port.
COLLAB_PORT=4445

# Database connection.
# In development the db provider is SQLite (a local file URL like the default
# below). In production it is PostgreSQL, so set this to your postgres:// URL.
DATABASE_URL=file:./keystone.db

# MindHive frontend origins (used for CORS and links in emails).
FRONTEND_URL_DEV=http://localhost:3000
FRONTEND_URL=https://dev.mindhive.science

# YouQuantified frontend origins.
FRONTEND_URL_DEV_YQ=http://localhost:5173
FRONTEND_URL_YQ=https://youquantified.com

# Public base URL for assets served by this backend (images/videos).
ASSET_BASE_URL_DEV=http://localhost:4444
ASSET_BASE_URL=https://backend.mindhive.science

# Session cookie signing secret. Use a long random string.
# Required in production; a temporary one is generated in dev if omitted.
SESSION_SECRET=replace-with-a-long-random-string
# Optional: domain the session cookie is scoped to in production.
# Defaults to ".mindhive.science".
#SESSION_COOKIE_DOMAIN=

# Postmark server token for transactional email (password resets, etc.).
MAIL_TOKEN=your-postmark-server-token

# Cloudinary credentials for media uploads/transforms.
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_KEY=your-cloudinary-api-key
CLOUDINARY_SECRET=your-cloudinary-api-secret
